{
   "compilerOptions": {
      "target": "ES2022",
      "module": "NodeNext",
      "moduleResolution": "NodeNext",

      // Project Structure 
      "outDir": "./dist",
      "rootDir": "./src",

      // Rules
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "ignoreDeprecations": "6.0",
      "baseUrl": ".",
      "paths": {
         "@/*": [
            "./src/*"
         ]
      }
   },
   // Only look for .ts in /src
   "include": ["src"] 
}
