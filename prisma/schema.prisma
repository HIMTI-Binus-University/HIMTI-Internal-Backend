enum EventVisibility {
   PUBLIC
   PRIVATE
}

enum IsOnsite {
   ONLINE
   OFFLINE
   HYBRID
}

generator client {
   provider = "prisma-client"
   output   = "../src/generated/prisma"
}

datasource db {
   provider = "postgresql"
   url      = env("DATABASE_URL")
}

model User {
   id            String    @id @default(nanoid())
   name          String    @db.VarChar(255)
   email         String    @unique @db.VarChar(100)
   emailVerified Boolean   @default(false)
   image         String?
   roleId        String?
   status        String    @default("p") @db.Char(1)
   createdAt     DateTime  @default(now()) @db.Timestamp(0)
   createdBy     String?   @db.VarChar(100)
   updatedAt     DateTime? @updatedAt()
   updatedBy     String?   @db.VarChar(100)

   role     Role?     @relation(fields: [roleId], references: [id], onDelete: Cascade)
   sessions Session[]
   accounts Account[]

   @@map("users")
}

model Role {
   id        String    @id @default(nanoid())
   roleName  String    @db.VarChar(255)
   status    String    @default("a") @db.Char(1)
   createdAt DateTime  @default(now()) @db.Timestamp(0)
   createdBy String    @db.VarChar(100)
   updatedAt DateTime? @updatedAt()
   updatedBy String?   @db.VarChar(100)

   user User[]

   @@map("roles")
}

model Session {
   id        String   @id @default(nanoid())
   expiresAt DateTime
   token     String   @unique
   ipAddress String?
   userAgent String?
   userId    String
   createdAt DateTime
   updatedAt DateTime

   user User @relation(fields: [userId], references: [id], onDelete: Cascade)

   @@map("sessions")
}

model Account {
   id                   String    @id @default(nanoid())
   accountId            String
   providerId           String
   userId               String
   accessToken          String?   @db.Text
   refreshToken         String?   @db.Text
   idToken              String?   @db.Text
   scope                String?   @db.Text
   password             String?   @db.Text
   accessTokenExpiresAt DateTime?
   createdAt            DateTime
   updatedAt            DateTime

   user User @relation(fields: [userId], references: [id], onDelete: Cascade)

   @@map("accounts")
}

model Verification {
   id         String    @id @default(nanoid())
   identifier String
   value      String
   expiresAt  DateTime
   createdAt  DateTime?
   updatedAt  DateTime?

   @@map("verifications")
}

model Url {
   id          String    @id @default(nanoid())
   shortCode   String    @unique @db.VarChar(21)
   originalUrl String    @db.Text
   expiresAt   DateTime?
   status      String    @default("a") @db.Char(1)
   createdAt   DateTime  @default(now()) @db.Timestamp(0)
   createdBy   String    @db.VarChar(100)
   updatedAt   DateTime? @updatedAt()
   updatedBy   String?   @db.VarChar(100)

   urlDetail UrlDetail[]

   @@map("urls")
}

model UrlDetail {
   id        String  @id @default(nanoid())
   urlId     String
   ip        String? @db.VarChar(255)
   userAgent String? @db.VarChar(255)
   country   String? @db.VarChar(255)
   region    String? @db.VarChar(255)
   city      String? @db.VarChar(255)
   latitude  Float?
   longitude Float?
   isp       String? @db.VarChar(255)
   timezone  String? @db.VarChar(255)

   url Url @relation(fields: [urlId], references: [id])

   @@map("url_details")
}

model Event {
   id                String          @id @default(nanoid())
   eventName         String          @db.VarChar(255)
   eventKicker       String          @db.VarChar(255)
   eventDesc         String          @db.Text
   eventDate         DateTime
   eventLocation     String          @db.VarChar(255)
   eventPriceOnline  Int
   eventPriceOffline Int
   isOnsite          IsOnsite
   eventVisibility   EventVisibility
   status            String          @default("a") @db.Char(1)
   createdAt         DateTime        @default(now()) @db.Timestamp(0)
   createdBy         String          @db.VarChar(100)
   updatedAt         DateTime?       @updatedAt()
   updatedBy         String?         @db.VarChar(100)

   eventHasParticipant EventHasParticipant[]

   @@map("events")
}

model EventHasParticipant {
   eventId       String
   participantId String
   event         Event       @relation(fields: [eventId], references: [id])
   participant   Participant @relation(fields: [participantId], references: [id])

   @@id([eventId, participantId])
   @@map("event_has_participants")
}

model Participant {
   id        String    @id @default(nanoid())
   eventId   String
   username  String    @db.VarChar(255)
   phone     String    @db.VarChar(255)
   binusian  String    @db.VarChar(255)
   region    String    @db.VarChar(255)
   jurusan   String    @db.VarChar(100)
   email     String    @unique @db.VarChar(100)
   nim       Int
   status    String    @default("a") @db.Char(1)
   createdAt DateTime  @default(now()) @db.Timestamp(0)
   createdBy String    @db.VarChar(100)
   updatedAt DateTime? @updatedAt()
   updatedBy String?   @db.VarChar(100)

   participantHasEvent EventHasParticipant[]

   @@map("participants")
}
