enum EventVisibility {
   PUBLIC
   PRIVATE
}

enum IsOnsite {
   ONLINE
   OFFLINE
   HYBRID
}

generator client {
   provider = "prisma-client"
   output   = "../src/generated/prisma"
}

datasource db {
   provider = "postgresql"
   url      = env("DATABASE_URL")
}

model Users {
   userId    String    @id @default(uuid()) @db.Uuid
   email     String    @unique @db.VarChar(100)
   roleId    String?   @db.Uuid
   status    String    @default("a") @db.Char(1)
   createdAt DateTime  @default(now()) @db.Timestamp(0)
   createdBy String    @db.VarChar(100)
   updatedAt DateTime? @updatedAt()
   updatedBy String?   @db.VarChar(100)

   roles Roles? @relation(fields: [roleId], references: [roleId])
}

model Roles {
   roleId    String    @id @default(uuid()) @db.Uuid
   roleName  String    @db.VarChar(255)
   status    String    @db.Char(1)
   createdAt DateTime  @default(now()) @db.Timestamp(0)
   createdBy String    @db.VarChar(100)
   updatedAt DateTime? @updatedAt()
   updatedBy String?   @db.VarChar(100)

   users Users[]
}

model Url {
   urlId       String    @id @default(uuid()) @db.Uuid
   shortCode   String    @unique @db.VarChar(21)
   originalUrl String    @db.Text
   expiresAt   DateTime?
   status      String    @default("a") @db.Char(1)
   createdAt   DateTime  @default(now()) @db.Timestamp(0)
   createdBy   String    @db.VarChar(100)
   updatedAt   DateTime? @updatedAt()
   updatedBy   String?   @db.VarChar(100)

   urlDetails UrlDetails[]
}

model UrlDetails {
   urlDetailsId String  @id @default(uuid()) @db.Uuid
   urlId        String  @db.Uuid
   ip           String? @db.VarChar(255)
   userAgent    String? @db.VarChar(255)
   country      String? @db.VarChar(255)
   region       String? @db.VarChar(255)
   city         String? @db.VarChar(255)
   latitude     Float?
   longitude    Float?
   isp          String? @db.VarChar(255)
   timezone     String? @db.VarChar(255)

   urlShortener Url @relation(fields: [urlId], references: [urlId])
}

model Events {
   eventId           String          @id @default(uuid()) @db.Uuid
   eventName         String          @db.VarChar(255)
   eventKicker       String          @db.VarChar(255)
   eventDesc         String          @db.Text
   eventDate         DateTime
   eventLocation     String          @db.VarChar(255)
   eventPriceOnline  Int
   eventPriceOffline Int
   isOnsite          IsOnsite
   eventVisibility   EventVisibility
   status            String          @default("a") @db.Char(1)
   createdAt         DateTime        @default(now()) @db.Timestamp(0)
   createdBy         String          @db.VarChar(100)
   updatedAt         DateTime?       @updatedAt()
   updatedBy         String?         @db.VarChar(100)

   eventsHasParticipants EventsHasParticipants[]
}

model EventsHasParticipants {
   eventId       String       @db.Uuid
   participantId String       @db.Uuid
   events        Events       @relation(fields: [eventId], references: [eventId])
   participants  Participants @relation(fields: [participantId], references: [participantId])

   @@id([eventId, participantId])
}

model Participants {
   participantId String    @id @default(uuid()) @db.Uuid
   eventId       String    @db.Uuid
   username      String    @db.VarChar(255)
   phone         String    @db.VarChar(255)
   binusian      String    @db.VarChar(255)
   region        String    @db.VarChar(255)
   jurusan       String    @db.VarChar(100)
   email         String    @unique @db.VarChar(100)
   nim           Int
   status        String    @default("a") @db.Char(1)
   createdAt     DateTime  @default(now()) @db.Timestamp(0)
   createdBy     String    @db.VarChar(100)
   updatedAt     DateTime? @updatedAt()
   updatedBy     String?   @db.VarChar(100)

   participantsHasEvents EventsHasParticipants[]
}
