generator client {
   provider = "prisma-client-js"
}

datasource db {
   provider = "postgresql"
   url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum UserStatus {
   ACTIVE
   INACTIVE
   SUSPENDED
}

enum MemberType {
   STUDENT
   LECTURER
   OTHER
}

enum InstitutionType {
   BINUS
   NON_BINUS
}

enum Status {
   ACTIVE
   INACTIVE
}

enum UniversityStatus {
   ACTIVE
   INACTIVE
}

enum StudyProgramStatus {
   ACTIVE
   INACTIVE
}

enum RoleStatus {
   ACTIVE
   INACTIVE
}

enum EventStatus {
   DRAFT
   PUBLISHED
   CLOSED
   CANCELLED
}

enum SubeventType {
   MAIN_EVENT
   WORKSHOP
   SEMINAR
   COMPETITION
   WELCOMING_PARTY
   DOMESTIC_STUDY_TOUR
   INTERNATIONAL_STUDY_TOUR
   COMPANY_VISIT
   OTHER
}

enum CommitteeRole {
   CHAIRPERSON
   VICE_CHAIRPERSON
   SECRETARY
   TREASURER
   COORDINATOR
   STAFF
}

enum SubeventVisibility {
   PUBLIC
   INTERNAL
   INVITE_ONLY // ?
}

enum SubeventStatus {
   DRAFT
   OPEN
   CLOSED
   CANCELLED
}

enum RegistrationStatus {
   PENDING
   APPROVED
   REJECTED
   CANCELLED
}

enum PaymentStatus {
   UNPAID
   SUBMITTED
   VERIFIED
   REJECTED
}

enum RegistrationResponseStatus {
   DRAFT
   SUBMITTED
   LOCKED
}

enum FormFieldType {
   TEXT
   TEXTAREA
   NUMBER
   DATE
   SELECT
   RADIO
   CHECKBOX
   FILE
}

enum FormQuestionStatus {
   ACTIVE
   INACTIVE
}

enum RegistrationFormStatus {
   DRAFT
   PUBLISHED
   CLOSED
}

// ==========================================
// ACADEMIC & INSTITUTION
// ==========================================

model University {
   id        String           @id @default(nanoid())
   name      String           @unique @db.VarChar(255)
   shortName String?          @db.VarChar(50)
   status    UniversityStatus @default(ACTIVE)
   createdAt DateTime         @default(now()) @db.Timestamp(0)
   updatedAt DateTime?        @updatedAt

   users User[]

   @@map("universities")
}

model StudyProgram {
   id        String             @id @default(nanoid())
   name      String             @unique @db.VarChar(255)
   shortName String?            @db.VarChar(50)
   status    StudyProgramStatus @default(ACTIVE)
   createdAt DateTime           @default(now()) @db.Timestamp(0)
   updatedAt DateTime?          @updatedAt

   users User[]

   @@map("study_programs")
}

model BinusRegion {
   id        String    @id @default(nanoid())
   name      String    @unique @db.VarChar(100)
   status    Status    @default(ACTIVE)
   createdAt DateTime  @default(now()) @db.Timestamp(0)
   updatedAt DateTime? @updatedAt

   users User[]

   @@map("binus_regions")
}

// ==========================================
// USER & AUTH
// ==========================================

model User {
   // Identity
   id                   String           @id @default(nanoid())
   name                 String           @db.VarChar(255)
   email                String           @unique @db.VarChar(100)
   emailVerified        Boolean          @default(false)
   outlookEmail         String?          @unique @db.VarChar(100)
   outlookEmailVerified Boolean          @default(false)
   image                String?
   status               UserStatus       @default(ACTIVE)
   memberType           MemberType?
   institutionType      InstitutionType?

   // BINUS Registration
   binusEmail           String?   @unique @db.VarChar(100)
   binusEmailVerified   Boolean   @default(false)
   binusEmailVerifiedAt DateTime? @db.Timestamp(0)
   binusRegionId        String?

   // Academic
   nim              String? @db.VarChar(50)
   universityId     String?
   universityName   String? @db.VarChar(255)
   studyProgramId   String?
   studyProgramName String? @db.VarChar(255)
   graduateBatch    String? @db.VarChar(20)
   department       String? @db.VarChar(255)
   affiliation      String? @db.VarChar(255)

   // Contact
   phoneNumber String? @db.VarChar(20)
   lineId      String? @db.VarChar(50)

   // Registration Completion
   registrationCompletedAt DateTime? @db.Timestamp(0)

   // Audit
   createdAt DateTime  @default(now()) @db.Timestamp(0)
   createdBy String?   @db.VarChar(100)
   updatedAt DateTime? @updatedAt
   updatedBy String?   @db.VarChar(100)

   // Relations
   university   University?   @relation(fields: [universityId], references: [id])
   studyProgram StudyProgram? @relation(fields: [studyProgramId], references: [id])
   binusRegion  BinusRegion?  @relation(fields: [binusRegionId], references: [id], onDelete: SetNull)

   sessions                Session[]
   accounts                Account[]
   binusEmailVerifications BinusEmailVerification[]
   userHasRoles            UserHasRole[]
   eventHasParticipants    EventHasParticipant[]

   // Ownership Relations (CreatedBy/UpdatedBy refs)
   createdEvents         Event[]                @relation("EventCreator")
   updatedEvents         Event[]                @relation("EventUpdater")
   createdSubevents      Subevent[]             @relation("SubeventCreator")
   updatedSubevents      Subevent[]             @relation("SubeventUpdater")
   createdForms          RegistrationForm[]     @relation("FormCreator")
   updatedForms          RegistrationForm[]     @relation("FormUpdater")
   createdQuestions      FormQuestion[]         @relation("QuestionCreator")
   updatedQuestions      FormQuestion[]         @relation("QuestionUpdater")
   createdOptions        FormQuestionOption[]   @relation("OptionCreator")
   updatedOptions        FormQuestionOption[]   @relation("OptionUpdater")
   approvedParticipants  EventHasParticipant[]  @relation("ParticipantApprover")
   verifiedPayments      EventHasParticipant[]  @relation("PaymentVerifier")
   registrationResponses RegistrationResponse[]
   eventComittees        EventComittee[]
   createdUrls           Url[]                  @relation("UrlCreator")
   updatedUrls           Url[]                  @relation("UrlUpdater")
   createdRoles          Role[]                 @relation("RoleCreator")
   updatedRoles          Role[]                 @relation("RoleUpdater")
   createdPermissions    Permission[]           @relation("PermissionCreator")
   updatedPermissions    Permission[]           @relation("PermissionUpdater")
   updatedUser           User[]                 @relation("UserUpdater")
   user                  User?                  @relation("UserUpdater", fields: [createdBy], references: [id])

   @@map("users")
}

model Session {
   id        String    @id @default(nanoid())
   token     String    @unique
   expiresAt DateTime
   ipAddress String?
   userAgent String?
   userId    String
   createdAt DateTime  @default(now()) @db.Timestamp(0)
   updatedAt DateTime? @updatedAt

   user User @relation(fields: [userId], references: [id], onDelete: Cascade)

   @@map("sessions")
}

model Account {
   id                   String    @id @default(nanoid())
   accountId            String
   providerId           String
   userId               String
   accessToken          String?   @db.Text
   refreshToken         String?   @db.Text
   idToken              String?   @db.Text
   scope                String?   @db.Text
   password             String?   @db.Text
   accessTokenExpiresAt DateTime?
   createdAt            DateTime  @default(now()) @db.Timestamp(0)
   updatedAt            DateTime? @updatedAt

   user User @relation(fields: [userId], references: [id], onDelete: Cascade)

   @@map("accounts")
}

model Verification {
   id         String    @id @default(nanoid())
   identifier String
   value      String
   expiresAt  DateTime
   createdAt  DateTime  @default(now()) @db.Timestamp(0)
   updatedAt  DateTime? @updatedAt

   @@map("verifications")
}

model BinusEmailVerification {
   id        String    @id @default(nanoid())
   userId    String
   email     String    @db.VarChar(100)
   tokenHash String    @unique @db.VarChar(64)
   expiresAt DateTime  @db.Timestamp(0)
   usedAt    DateTime? @db.Timestamp(0)
   createdAt DateTime  @default(now()) @db.Timestamp(0)

   user User @relation(fields: [userId], references: [id], onDelete: Cascade)

   @@index([userId, email, createdAt])
   @@map("binus_email_verifications")
}

// ==========================================
// RBAC (ROLES & PERMISSIONS)
// ==========================================

model Role {
   id        String     @id @default(nanoid())
   roleName  String     @unique @db.VarChar(255)
   status    RoleStatus @default(ACTIVE)
   createdAt DateTime   @default(now()) @db.Timestamp(0)
   createdBy String     @db.VarChar(100)
   updatedAt DateTime?  @updatedAt
   updatedBy String?    @db.VarChar(100)

   creator User  @relation("RoleCreator", fields: [createdBy], references: [id])
   updater User? @relation("RoleUpdater", fields: [updatedBy], references: [id])

   roleHasUsers       UserHasRole[]
   roleHasPermissions RoleHasPermission[]

   @@map("roles")
}

model Permission {
   id        String    @id @default(nanoid())
   name      String    @unique @db.VarChar(255)
   status    Status    @default(ACTIVE)
   createdAt DateTime  @default(now()) @db.Timestamp(0)
   createdBy String    @db.VarChar(100)
   updatedBy String?   @db.VarChar(100)
   updatedAt DateTime? @updatedAt

   permissionHasRoles RoleHasPermission[]
   creator            User                @relation("PermissionCreator", fields: [createdBy], references: [id])
   updater            User?               @relation("PermissionUpdater", fields: [updatedBy], references: [id])

   @@map("permissions")
}

model UserHasRole {
   userId     String
   roleId     String
   assignedAt DateTime @default(now()) @db.Timestamp(0)

   user User @relation(fields: [userId], references: [id], onDelete: Cascade)
   role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

   @@id([userId, roleId])
   @@map("user_has_roles")
}

model RoleHasPermission {
   roleId       String
   permissionId String
   assignedAt   DateTime @default(now()) @db.Timestamp(0)

   role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
   permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

   @@id([roleId, permissionId])
   @@map("role_has_permissions")
}

// ==========================================
// EVENTS & SUBEVENTS
// ==========================================

model Event {
   id                String      @id @default(nanoid())
   name              String      @db.VarChar(255)
   publicDescription String?     @db.Text
   coverImageUrl     String?     @db.Text
   status            EventStatus @default(DRAFT)

   createdAt DateTime  @default(now()) @db.Timestamp(0)
   createdBy String    @db.VarChar(100)
   updatedAt DateTime? @updatedAt
   updatedBy String?   @db.VarChar(100)

   creator User  @relation("EventCreator", fields: [createdBy], references: [id])
   updater User? @relation("EventUpdater", fields: [updatedBy], references: [id])

   subevents            Subevent[]
   eventHasParticipants EventHasParticipant[]
   eventComittees       EventComittee[]

   @@map("events")
}

model Subevent {
   id                 String       @id @default(nanoid())
   eventId            String
   name               String       @db.VarChar(255)
   publicDescription  String?      @db.Text
   privateDescription String?      @db.Text
   date               DateTime
   type               SubeventType
   locationName       String?      @db.VarChar(255)
   locationUrl        String?      @db.Text
   price              Int          @default(0)

   // Payment fields
   paid                 Boolean @default(false)
   paymentAccountBank   String  @db.VarChar(100)
   paymentAccountNumber Int?
   paymentAccountName   String? @db.VarChar(100)
   priceModifier        Int?
   paymentDesc          String  @db.VarChar(255)

   // Registration Rules
   maxParticipants        Int?
   maxTicketsPerUser      Int?
   isRegistrationOpen     Boolean @default(false)
   autoAcceptRegistration Boolean @default(false)
   checkOutToken          String? @db.VarChar(255)

   visibility SubeventVisibility @default(PUBLIC)
   status     SubeventStatus     @default(DRAFT)

   createdAt DateTime  @default(now()) @db.Timestamp(0)
   createdBy String    @db.VarChar(100)
   updatedAt DateTime? @updatedAt
   updatedBy String?   @db.VarChar(100)

   event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
   creator User  @relation("SubeventCreator", fields: [createdBy], references: [id])
   updater User? @relation("SubeventUpdater", fields: [updatedBy], references: [id])

   participants      EventHasParticipant[]
   registrationForms RegistrationForm[]

   @@map("subevents")
}

model EventHasParticipant {
   id          String @id @default(nanoid())
   eventId     String
   eventModeId String
   userId      String

   // Status
   registrationStatus RegistrationStatus @default(PENDING)
   approvedAt         DateTime?
   approvedBy         String?            @db.VarChar(100)

   // Payment
   paymentStatus      PaymentStatus @default(UNPAID)
   paymentProofUrl    String?       @db.Text
   paymentSubmittedAt DateTime?
   paymentVerifiedAt  DateTime?
   paymentVerifiedBy  String?       @db.VarChar(100)

   createdAt DateTime  @default(now()) @db.Timestamp(0)
   updatedAt DateTime? @updatedAt

   event    Event    @relation(fields: [eventId], references: [id])
   subevent Subevent @relation(fields: [eventModeId], references: [id])
   user     User     @relation(fields: [userId], references: [id])

   approver User? @relation("ParticipantApprover", fields: [approvedBy], references: [id])
   verifier User? @relation("PaymentVerifier", fields: [paymentVerifiedBy], references: [id])

   registrationResponses RegistrationResponse[]

   @@unique([eventId, userId, eventModeId])
   @@map("event_has_participants")
}

model EventComittee {
   eventId    String
   userId     String
   role       CommitteeRole @default(STAFF)
   assignedAt DateTime      @default(now()) @db.Timestamp(0)

   event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
   user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

   @@id([eventId, userId])
   @@map("event_committees")
}

// ==========================================
// REGISTRATION FORM BUILDER
// ==========================================

model RegistrationForm {
   id         String                 @id @default(nanoid())
   subEventId String
   status     RegistrationFormStatus @default(DRAFT)

   createdAt DateTime  @default(now()) @db.Timestamp(0)
   createdBy String    @db.VarChar(100)
   updatedAt DateTime? @updatedAt
   updatedBy String?   @db.VarChar(100)

   subEvent Subevent @relation(fields: [subEventId], references: [id], onDelete: Cascade)
   creator  User     @relation("FormCreator", fields: [createdBy], references: [id])
   updater  User?    @relation("FormUpdater", fields: [updatedBy], references: [id])

   questions             FormQuestion[]
   registrationResponses RegistrationResponse[]

   @@map("registration_forms")
}

model FormQuestion {
   id                 String             @id @default(nanoid())
   registrationFormId String
   label              String             @db.VarChar(255)
   fieldKey           String             @db.VarChar(100)
   fieldType          FormFieldType
   isRequired         Boolean            @default(true)
   helpText           String?            @db.Text
   orderIndex         Int                @default(0)
   status             FormQuestionStatus @default(ACTIVE)

   createdAt DateTime  @default(now()) @db.Timestamp(0)
   createdBy String    @db.VarChar(100)
   updatedAt DateTime? @updatedAt
   updatedBy String?   @db.VarChar(100)

   form    RegistrationForm @relation(fields: [registrationFormId], references: [id], onDelete: Cascade)
   creator User             @relation("QuestionCreator", fields: [createdBy], references: [id])
   updater User?            @relation("QuestionUpdater", fields: [updatedBy], references: [id])

   options     FormQuestionOption[]
   formAnswers FormAnswer[]

   @@map("form_questions")
}

model FormQuestionOption {
   id             String  @id @default(nanoid())
   formQuestionId String
   label          String  @db.VarChar(255)
   value          String  @db.VarChar(255)
   isActive       Boolean @default(true)

   createdAt DateTime  @default(now()) @db.Timestamp(0)
   createdBy String    @db.VarChar(100)
   updatedAt DateTime? @updatedAt
   updatedBy String?   @db.VarChar(100)

   question FormQuestion @relation(fields: [formQuestionId], references: [id], onDelete: Cascade)
   creator  User         @relation("OptionCreator", fields: [createdBy], references: [id])
   updater  User?        @relation("OptionUpdater", fields: [updatedBy], references: [id])

   @@map("form_question_options")
}

model RegistrationResponse {
   id                    String                     @id @default(nanoid())
   eventHasParticipantId String
   registrationFormId    String
   userId                String
   status                RegistrationResponseStatus @default(DRAFT)
   submittedAt           DateTime?

   createdAt DateTime  @default(now()) @db.Timestamp(0)
   updatedAt DateTime? @updatedAt

   participant      EventHasParticipant @relation(fields: [eventHasParticipantId], references: [id], onDelete: Cascade)
   registrationForm RegistrationForm    @relation(fields: [registrationFormId], references: [id])
   user             User                @relation(fields: [userId], references: [id])

   answers FormAnswer[]

   @@map("registration_responses")
}

model FormAnswer {
   id                     String  @id @default(nanoid())
   registrationResponseId String
   formQuestionId         String
   value                  String? @db.Text
   selectedOptionValue    String? @db.VarChar(255)
   fileUrl                String? @db.Text

   createdAt DateTime  @default(now()) @db.Timestamp(0)
   updatedAt DateTime? @updatedAt

   response RegistrationResponse @relation(fields: [registrationResponseId], references: [id], onDelete: Cascade)
   question FormQuestion         @relation(fields: [formQuestionId], references: [id])

   @@map("form_answers")
}

// ==========================================
// URL Shortener
// ==========================================

model Url {
   id          String    @id @default(nanoid())
   shortCode   String    @unique @db.VarChar(100)
   originalUrl String    @db.Text
   expiresAt   DateTime?
   status      Status    @default(ACTIVE)
   createdAt   DateTime  @default(now()) @db.Timestamp(0)
   updatedAt   DateTime? @updatedAt

   createdBy String  @db.VarChar(100)
   updatedBy String? @db.VarChar(100)

   creator User  @relation("UrlCreator", fields: [createdBy], references: [id])
   updater User? @relation("UrlUpdater", fields: [updatedBy], references: [id])

   urlDetails UrlDetail[]

   @@map("urls")
}

model UrlDetail {
   id        String   @id @default(nanoid())
   urlId     String
   ip        String?  @db.VarChar(255)
   userAgent String?  @db.VarChar(255)
   country   String?  @db.VarChar(255)
   region    String?  @db.VarChar(255)
   city      String?  @db.VarChar(255)
   latitude  Float?
   longitude Float?
   isp       String?  @db.VarChar(255)
   timezone  String?  @db.VarChar(255)
   clickedAt DateTime @default(now()) @db.Timestamp(0)

   url Url @relation(fields: [urlId], references: [id])

   @@map("url_details")
}
